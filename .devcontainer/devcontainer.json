{
  "name": "Lightweight Jekyll Devcontainer",
  "image": "mcr.microsoft.com/devcontainers/ruby:3.2",

  "forwardPorts": [4000],
  "portsAttributes": {
    "4000": {
      "label": "Jekyll Preview",
      "onAutoForward": "openBrowser"
    }
  },

  "postCreateCommand": "git submodule update --init --recursive && gem install bundler github-pages && bundle install",
  "postStartCommand": "bundle exec jekyll serve --livereload --host 0.0.0.0",

  "customizations": {
    "vscode": {
      "extensions": [
        "rebornix.ruby",
        "shopify.ruby-lsp"
      ]
    }
  }
}
