{
  "name": "Jekyll GitHub Pages Devcontainer",
  "dockerFile": "Dockerfile",

  "forwardPorts": [4000],
  "portsAttributes": {
    "4000": {
      "label": "Jekyll Preview",
      "onAutoForward": "openBrowser"
    }
  },

  "postCreateCommand": "git submodule update --init --recursive && bundle install",

  "postStartCommand": "bundle exec jekyll serve --livereload --host 0.0.0.0",

  "customizations": {
    "vscode": {
      "extensions": [
        "rebornix.ruby",
        "shopify.ruby-lsp",
        "ritwickdey.liveserver",
        "github.vscode-github-actions"
      ]
    }
  }
}
